{{ 'livrome-tokens.css' | asset_url | stylesheet_tag }}

<style>
  .ph-lib__head { display: flex; justify-content: space-between; align-items: flex-end; gap: 32px; margin-bottom: 56px; flex-wrap: wrap; }
  .ph-lib__head .ph-title { margin-bottom: 12px; }
  .ph-lib__filters { display: flex; gap: 8px; flex-wrap: wrap; }
  .ph-lib__filter { padding: 10px 18px; border: 1px solid var(--ph-ink-15); border-radius: 999px; background: transparent; font-size: 13px; font-family: var(--ph-font-body); color: var(--ph-ink); cursor: pointer; transition: all 0.2s; }
  .ph-lib__filter.is-active, .ph-lib__filter:hover { background: var(--ph-plum); color: var(--ph-cream); border-color: var(--ph-plum); }
  .ph-lib__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px 32px; }
  @media (max-width: 900px) { .ph-lib__grid { grid-template-columns: repeat(2, 1fr); } }
  .ph-book { text-decoration: none; color: inherit; display: block; }
  .ph-book__cover { aspect-ratio: 3/4; background: var(--ph-cream-deep); border-radius: 6px; overflow: hidden; margin-bottom: 18px; position: relative; box-shadow: -2px 4px 0 var(--ph-ink-08); transition: transform 0.25s ease; }
  .ph-book:hover .ph-book__cover { transform: translate(2px, -2px); box-shadow: -4px 6px 0 var(--ph-ink-08); }
  .ph-book__cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ph-book__cover--empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; text-align: center; font-family: var(--ph-font-display); font-style: italic; color: var(--ph-plum); height: 100%; }
  .ph-book__cover--empty span { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ph-honey-deep); margin-top: 12px; font-style: normal; }
  .ph-book__badge { position: absolute; top: 12px; left: 12px; background: var(--ph-honey); color: var(--ph-plum-deep); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border-radius: 2px; font-weight: 600; }
  .ph-book__title { font-family: var(--ph-font-display); font-size: 18px; line-height: 1.25; margin: 0 0 4px; font-weight: 500; }
  .ph-book__meta { font-size: 13px; color: var(--ph-ink-60); margin: 0 0 8px; font-style: italic; }
  .ph-book__price { font-size: 14px; font-weight: 500; }
</style>

<section class="ph-section ph-section--paper">
  <div class="ph-inner">
    <div class="ph-lib__head">
      <div>
        {% if section.settings.eyebrow != blank %}<p class="ph-eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        <h2 class="ph-title">{{ section.settings.heading }}</h2>
        {% if section.settings.lede != blank %}<p class="ph-lede" style="margin: 0;">{{ section.settings.lede }}</p>{% endif %}
      </div>
      {% if section.blocks.size > 0 %}
        <div class="ph-lib__filters">
          {% for block in section.blocks %}
            {% if block.type == 'filter' %}
              <button class="ph-lib__filter{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.label }}</button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="ph-lib__grid">
      {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
        {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
          <a href="{{ product.url }}" class="ph-book">
            <div class="ph-book__cover">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: widths: '300, 600', loading: 'lazy' }}
              {% else %}
                <div class="ph-book__cover--empty">{{ product.title }}<span>Personalized</span></div>
              {% endif %}
              {% if product.tags contains 'featured' %}<span class="ph-book__badge">Featured</span>{% endif %}
            </div>
            <h3 class="ph-book__title">{{ product.title }}</h3>
            {% if product.metafields.livrome.age_range.value != blank %}
              <p class="ph-book__meta">{{ product.metafields.livrome.age_range.value }}</p>
            {% endif %}
            <p class="ph-book__price">{{ product.price | money }}</p>
          </a>
        {% endfor %}
      {% else %}
        {% comment %} Placeholder tiles — 8 canonical Livrome stories from UI/i18n.jsx {% endcomment %}
        {%- assign placeholder_titles = "Léo and the Stars|The Whispering Forest|Under the Great Wave|The Red Balloon|The Winter Lantern|Grandma's Garden|The Flying Alphabet|The Moon's Sister" | split: "|" -%}
        {%- assign placeholder_ages = 'Ages 3–6|Ages 4–7|Ages 5–8|Ages 3–5|Ages 5–8|Ages 4–7|Ages 4–6|Ages 5–8' | split: '|' -%}
        {% for i in (0..7) %}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="ph-book">
            <div class="ph-book__cover">
              <div class="ph-book__cover--empty">{{ placeholder_titles[i] }}<span>Coming soon</span></div>
              {% if forloop.first %}<span class="ph-book__badge">Available now</span>{% endif %}
            </div>
            <h3 class="ph-book__title">{{ placeholder_titles[i] }}</h3>
            <p class="ph-book__meta">{{ placeholder_ages[i] }}</p>
            <p class="ph-book__price">From $29.00 CAD</p>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Livrome · Library",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The library" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose your story" },
    { "type": "textarea", "id": "lede", "label": "Supporting text", "default": "Eight original tales, written by our authors, for every age and every night." },
    { "type": "collection", "id": "collection", "label": "Collection (optional — uses placeholders when empty)" },
    { "type": "url", "id": "cta_link", "label": "Placeholder tile link", "info": "Used when no collection is set, e.g. /pages/coming-soon" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 }
  ],
  "blocks": [
    {
      "type": "filter",
      "name": "Filter pill",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "All" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Livrome · Library",
      "blocks": [
        { "type": "filter", "settings": { "label": "All" } },
        { "type": "filter", "settings": { "label": "Bedtime" } },
        { "type": "filter", "settings": { "label": "Adventure" } },
        { "type": "filter", "settings": { "label": "Emotions" } },
        { "type": "filter", "settings": { "label": "Family" } }
      ]
    }
  ]
}
{% endschema %}
