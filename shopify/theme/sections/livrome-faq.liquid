{{ 'livrome-tokens.css' | asset_url | stylesheet_tag }}

<style>
  .ph-faq__grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(32px, 6vw, 96px); align-items: start; }
  @media (max-width: 900px) { .ph-faq__grid { grid-template-columns: 1fr; } }
  .ph-faq__list { display: flex; flex-direction: column; }
  .ph-faq__item { border-top: 1px solid var(--ph-ink-15); }
  .ph-faq__item:last-child { border-bottom: 1px solid var(--ph-ink-15); }
  .ph-faq__item > summary { list-style: none; padding: 28px 0; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 24px; font-family: var(--ph-font-display); font-size: 22px; font-weight: 500; letter-spacing: -0.005em; }
  .ph-faq__item > summary::-webkit-details-marker { display: none; }
  .ph-faq__item > summary::after { content: '+'; font-family: var(--ph-font-body); font-size: 24px; color: var(--ph-plum); transition: transform 0.2s ease; flex-shrink: 0; }
  .ph-faq__item[open] > summary::after { transform: rotate(45deg); }
  .ph-faq__answer { padding: 0 0 28px; color: var(--ph-ink-60); font-size: 15px; line-height: 1.65; max-width: 60ch; }
  .ph-faq__cta { display: inline-flex; align-items: center; gap: 6px; margin-top: 24px; font-size: 14px; font-weight: 500; color: var(--ph-plum); text-decoration: none; border-bottom: 1px solid var(--ph-plum); padding-bottom: 2px; }
</style>

<section class="ph-section ph-section--paper">
  <div class="ph-inner ph-faq__grid">
    <div>
      {% if section.settings.eyebrow != blank %}<p class="ph-eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
      <h2 class="ph-title">{{ section.settings.heading }}</h2>
      {% if section.settings.lede != blank %}<p class="ph-lede">{{ section.settings.lede }}</p>{% endif %}
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_link | default: '/pages/faq' }}" class="ph-faq__cta">{{ section.settings.cta_label }} →</a>
      {% endif %}
    </div>

    <div class="ph-faq__list">
      {% for block in section.blocks %}
        {% if block.type == 'qa' %}
          <details class="ph-faq__item"{% if forloop.first %} open{% endif %} {{ block.shopify_attributes }}>
            <summary>{{ block.settings.question }}</summary>
            <div class="ph-faq__answer">{{ block.settings.answer }}</div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Livrome · FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Frequently asked" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Parents often ask…" },
    { "type": "textarea", "id": "lede", "label": "Supporting text", "default": "A short list of the questions we hear most. Can't find yours? Email us directly." },
    { "type": "text", "id": "cta_label", "label": "Link to full FAQ page", "default": "See all questions" },
    { "type": "url", "id": "cta_link", "label": "Full FAQ link" }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    { "name": "Livrome · FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "What do you do with my child's photo?", "answer": "It's used only to create your book, kept encrypted, and deleted within 30 days — or instantly on request from your account. We never share photos, never train models on them, never use them for anything else." } },
        { "type": "qa", "settings": { "question": "How long does delivery take?", "answer": "5–8 business days in Canada, 7–12 days to the US and Europe. Printing takes 48 hours once you've confirmed your preview." } },
        { "type": "qa", "settings": { "question": "Are the books available in French?", "answer": "Yes — every story is hand-written in both French (Quebec variant) and English. You choose the language when you create the book." } },
        { "type": "qa", "settings": { "question": "What if I don't love the final book?", "answer": "We'll replace it or refund you. No fine print, no return shipping fees. We only ship books we'd be proud to keep ourselves." } }
      ]
    }
  ]
}
{% endschema %}
