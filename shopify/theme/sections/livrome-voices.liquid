{{ 'livrome-tokens.css' | asset_url | stylesheet_tag }}

<style>
  .ph-voices__head { max-width: 640px; margin: 0 auto 56px; text-align: center; }
  .ph-voices__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 900px) { .ph-voices__grid { grid-template-columns: 1fr; } }
  .ph-voice { background: var(--ph-paper); padding: 36px 32px; border-radius: 8px; display: flex; flex-direction: column; gap: 20px; box-shadow: 0 2px 8px rgba(42, 20, 58, 0.06); }
  .ph-voice__quote { font-family: var(--ph-font-display); font-size: 20px; line-height: 1.4; letter-spacing: -0.005em; margin: 0; flex: 1; }
  .ph-voice__quote::before { content: '"'; font-size: 48px; color: var(--ph-honey); line-height: 0.5; display: block; margin-bottom: 16px; font-family: var(--ph-font-display); }
  .ph-voice__author { display: flex; align-items: center; gap: 14px; padding-top: 20px; border-top: 1px solid var(--ph-ink-15); }
  .ph-voice__avatar { width: 44px; height: 44px; border-radius: 999px; background: var(--ph-cream-deep); display: flex; align-items: center; justify-content: center; font-family: var(--ph-font-display); font-style: italic; color: var(--ph-plum); flex-shrink: 0; font-weight: 500; }
  .ph-voice__name { font-size: 14px; font-weight: 600; margin: 0; }
  .ph-voice__role { font-size: 13px; color: var(--ph-ink-60); margin: 0; font-style: italic; }
</style>

<section class="ph-section ph-section--cream-deep">
  <div class="ph-inner">
    <div class="ph-voices__head">
      {% if section.settings.eyebrow != blank %}<p class="ph-eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
      <h2 class="ph-title">{{ section.settings.heading }}</h2>
    </div>

    <div class="ph-voices__grid">
      {% for block in section.blocks %}
        {% if block.type == 'voice' %}
          <figure class="ph-voice" {{ block.shopify_attributes }}>
            <blockquote class="ph-voice__quote">{{ block.settings.quote }}</blockquote>
            <figcaption class="ph-voice__author">
              <div class="ph-voice__avatar">{{ block.settings.name | slice: 0 }}</div>
              <div>
                <p class="ph-voice__name">{{ block.settings.name }}</p>
                <p class="ph-voice__role">{{ block.settings.role }}</p>
              </div>
            </figcaption>
          </figure>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Livrome · Voices",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Voices" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What families write to us." }
  ],
  "blocks": [
    {
      "type": "voice",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "role", "label": "Role" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Livrome · Voices",
      "blocks": [
        { "type": "voice", "settings": { "quote": "My daughter sleeps with this book. She introduces it to her friends as 'her own book.' I've never seen anything like it.", "name": "Camille", "role": "Mom of Léa, 5 · Montréal" } },
        { "type": "voice", "settings": { "quote": "Arrived before Christmas, beautifully packaged, quality worthy of an indie publisher. My grandson was speechless.", "name": "Jean-Paul", "role": "Grandfather · Québec City" } },
        { "type": "voice", "settings": { "quote": "As a parent I was wary of AI. But this is done with taste. The illustration is faithful, not uncanny.", "name": "Sarah", "role": "Mom of Noah, 4 · Toronto" } }
      ]
    }
  ]
}
{% endschema %}
