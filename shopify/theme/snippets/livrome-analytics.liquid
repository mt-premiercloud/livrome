{% comment %}
  Livrome analytics — GA4 loader with consent gating.

  Enable: Theme editor → Theme settings → "Analytics" → paste your GA4
  Measurement ID (e.g. G-XXXXXXXXXX). Leave blank to skip entirely.

  Consent: we set analytics_storage=denied by default via gtag('consent',
  'default', …). The cookie banner (livrome-cookie-consent.js) calls
  gtag('consent', 'update', { analytics_storage: 'granted' }) when the
  visitor opts into Analytics. If they don't opt in, GA4 receives
  cookie-less pings only.
{% endcomment %}

{%- if settings.ga4_measurement_id != blank -%}
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){ dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('consent', 'default', {
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'analytics_storage': 'denied',
    'wait_for_update': 500
  });

  (function () {
    try {
      var raw = document.cookie.match(/(?:^|; )ph_consent=([^;]*)/);
      if (!raw) return;
      var state = JSON.parse(decodeURIComponent(raw[1]));
      if (state && state.analytics) {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      }
      if (state && state.marketing) {
        gtag('consent', 'update', { ad_storage: 'granted', ad_user_data: 'granted', ad_personalization: 'granted' });
      }
    } catch (e) {}
  })();

  gtag('config', '{{ settings.ga4_measurement_id }}', {
    anonymize_ip: true,
    send_page_view: true
  });
</script>
<script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_measurement_id }}"></script>
{%- endif -%}
